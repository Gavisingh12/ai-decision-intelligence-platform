APP_NAME=AI Decision Intelligence Platform
APP_ENV=development
SECRET_KEY=replace-with-a-long-random-string
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/decision_intelligence
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

FREE_MODE=true
FREE_DEPLOY_TARGET=huggingface-spaces
PUBLIC_API_BASE_URL=
REQUEST_LIMIT_PER_MINUTE=90
MAX_DOCUMENT_CHUNKS=120
SHAP_REFERENCE_SAMPLE_SIZE=120
RECENT_TASK_LIMIT=8

DEFAULT_LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
HF_TOKEN=
HF_PERSIST_REPO_ID=
HF_PERSIST_REPO_PRIVATE=true
